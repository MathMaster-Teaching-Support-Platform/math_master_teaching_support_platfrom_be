@startuml

title Student Learning Roadmap Flow
autonumber

actor Student
participant ": LearningRoadmapView" as View
participant ": RoadmapController" as Controller
participant ": RoadmapServiceImpl" as Service
participant ": RoadmapRepositoryFacade\n(Enrollment/Course/Progress Repos)" as Repo
database "Database" as DB
participant "Gemini API" as AI

== Build Roadmap ==
Student -> View: Open "My Learning Roadmap"
activate View
View -> Controller: GET /students/me/roadmap?courseId={id}
activate Controller
Controller -> Service: getOrGenerateRoadmap(courseId)
activate Service

Service -> Repo: find active enrollment
activate Repo
Repo -> DB: SELECT enrollment by student and course
activate DB
DB --> Repo: enrollment row or empty
deactivate DB
Repo --> Service: enrollment
deactivate Repo

alt enrollment not active
  Service --> Controller: throw ENROLLMENT_REQUIRED
  deactivate Service
  Controller --> View: 403 Forbidden
  deactivate Controller
  deactivate View
else enrolled
  Service -> Repo: load lesson progress + upcoming lessons
  activate Repo
  Repo -> DB: SELECT lesson progress and curriculum
  activate DB
  DB --> Repo: progress dataset
  deactivate DB
  Repo --> Service: dataset
  deactivate Repo

  Service -> AI: sendMessage(personalized roadmap prompt)
  activate AI
  AI --> Service: milestone plan or error
  deactivate AI

  alt AI unavailable
    Service -> Service: fallback to rule-based roadmap
  else AI generated
    Service -> Service: merge AI milestones with curriculum constraints
  end

  Service --> Controller: StudentRoadmapResponse
  deactivate Service
  Controller --> View: 200 OK
  deactivate Controller
  View --> Student: Show timeline and next actions
  deactivate View
end

@enduml
