@startuml

title Slide Generate Flow
autonumber

actor Teacher
participant ": LessonSlideView" as View
participant ": LessonSlideController" as Controller
participant ": LessonSlideServiceImpl" as Service
participant ": LessonSlideRepositoryFacade\n(Lesson/Template/Asset Repos)" as Repo
database "Database" as DB
participant "Gemini API" as AI

== Generate Slide ==
Teacher -> View: Click "Generate Slide"
activate View
View -> Controller: POST /lesson-slides/generate-pptx-from-json(request)
activate Controller
Controller -> Service: generatePptxFromJson(request)
activate Service

Service -> Service: validate teacher role + request body

Service -> Repo: find lesson by id
activate Repo
Repo -> DB: SELECT lesson (not deleted)
activate DB
DB --> Repo: lesson row or empty
deactivate DB
Repo --> Service: lesson
deactivate Repo

Service -> Repo: find template by id
activate Repo
Repo -> DB: SELECT slide_template (active)
activate DB
DB --> Repo: template row or empty
deactivate DB
Repo --> Service: template
deactivate Repo

alt lesson/template invalid
  Service --> Controller: throw LESSON_OR_TEMPLATE_NOT_USABLE
  deactivate Service
  Controller --> View: error response
  deactivate Controller
  deactivate View
else valid input
  Service -> AI: sendMessage(slide generation prompt)
  activate AI
  AI --> Service: generated slide content or error
  deactivate AI

  alt AI generation failed
    Service --> Controller: throw TEMPLATE_GENERATION_FAILED
    deactivate Service
    Controller --> View: error response
    deactivate Controller
    deactivate View
  else AI generation success
    loop For each slide item
      Service -> Service: inject generated content into template
    end

    Service -> Service: build output file name and binary stream
    Service --> Controller: BinaryFileData(.pptx)
    deactivate Service
    Controller --> View: 200 OK (attachment .pptx)
    deactivate Controller
    View --> Teacher: Download generated slide
    deactivate View
  end
end

@enduml
