@startuml

title Quiz Generate Flow
autonumber

actor Teacher
participant ": QuizGeneratorView" as View
participant ": QuizController" as Controller
participant ": QuizServiceImpl" as Service
participant ": QuizRepositoryFacade\n(Quiz/Question/Tag Repos)" as Repo
database "Database" as DB
participant "Gemini API" as AI

== Generate Quiz ==
Teacher -> View: Click "Generate Quiz"
activate View
View -> Controller: POST /quizzes/generate(request)
activate Controller
Controller -> Service: generateQuiz(request)
activate Service

Service -> Service: validate teacher role + numberOfQuestions + difficulty

Service -> Repo: find source lesson/chapter
activate Repo
Repo -> DB: SELECT source content
activate DB
DB --> Repo: source row or empty
deactivate DB
Repo --> Service: source
deactivate Repo

alt source not found
  Service --> Controller: throw SOURCE_NOT_FOUND
  deactivate Service
  Controller --> View: 404 Not Found
  deactivate Controller
  deactivate View
else source found
  Service -> AI: sendMessage(generate question bank prompt)
  activate AI
  AI --> Service: question list or error
  deactivate AI

  alt invalid quiz payload
    Service --> Controller: throw QUIZ_GENERATION_FAILED
    deactivate Service
    Controller --> View: error response
    deactivate Controller
    deactivate View
  else valid payload
    Service -> Service: de-duplicate and shuffle options

    Service -> Repo: save quiz + questions
    activate Repo
    Repo -> DB: INSERT quiz and question rows
    activate DB
    DB --> Repo: saved quiz id
    deactivate DB
    Repo --> Service: persisted quiz
    deactivate Repo

    Service --> Controller: QuizResponse
    deactivate Service
    Controller --> View: 201 Created
    deactivate Controller
    View --> Teacher: Open quiz editor
    deactivate View
  end
end

@enduml
