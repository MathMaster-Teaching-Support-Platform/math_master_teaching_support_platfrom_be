# Default: force LF for all text files
* text=auto eol=lf

# Maven wrapper (Unix)
mvnw text eol=lf

# Windows command scripts
*.cmd text eol=crlf
*.bat text eol=crlf

# Shell scripts
*.sh text eol=lf

# Properties / config
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Java source
*.java text eol=lf
