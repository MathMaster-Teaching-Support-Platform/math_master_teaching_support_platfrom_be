<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">

    <!-- ── Import Spring Boot defaults (color converters, etc.) ── -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- ── Console pattern: HH:mm:ss LEVEL [logger-short] : message ── -->
    <property name="CONSOLE_PATTERN"
              value="%clr(%d{HH:mm:ss}){faint} %clr(%5p) %clr(%-35.35logger{34}){cyan} %clr(:){faint} %m%n%wEx"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ══════════════════ Noise Suppression ══════════════════ -->

    <!-- Redis / Lettuce -->
    <logger name="io.lettuce"                                          level="WARN"/>
    <logger name="io.lettuce.core.protocol"                            level="ERROR"/>
    <logger name="org.springframework.data.redis"                      level="WARN"/>

    <!-- Spring internals -->
    <logger name="org.springframework.web"                             level="WARN"/>
    <logger name="org.springframework.security"                        level="WARN"/>
    <logger name="org.springframework.boot.autoconfigure"              level="WARN"/>
    <logger name="org.springframework.boot.web.embedded.tomcat"        level="WARN"/>
    <logger name="org.springframework.orm.jpa"                         level="WARN"/>
    <logger name="org.springframework.transaction"                     level="WARN"/>

    <!-- Hibernate: show nothing except explicit SQL logging -->
    <logger name="org.hibernate"                                       level="WARN"/>
    <logger name="org.hibernate.SQL"                                   level="WARN"/>
    <logger name="org.hibernate.type.descriptor.sql"                   level="WARN"/>
    <logger name="org.hibernate.engine.jdbc.env.internal"              level="ERROR"/>
    <logger name="org.hibernate.validator"                             level="WARN"/>

    <!-- HikariCP: only show pool creation, not every borrow/return -->
    <logger name="com.zaxxer.hikari"                                   level="WARN"/>

    <!-- Springdoc / Swagger scanner -->
    <logger name="org.springdoc"                                       level="WARN"/>

    <!-- Jackson -->
    <logger name="com.fasterxml.jackson"                               level="WARN"/>

    <!-- Tomcat -->
    <logger name="org.apache.tomcat"                                   level="WARN"/>
    <logger name="org.apache.catalina"                                 level="WARN"/>

    <!-- ══════════════════ App loggers ══════════════════ -->

    <!-- Your application code: keep INFO -->
    <logger name="com.fptu.math_master" level="INFO"/>

    <!-- ══════════════════ Root ══════════════════ -->
    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
