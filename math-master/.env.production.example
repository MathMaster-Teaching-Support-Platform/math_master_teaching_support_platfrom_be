# Production Environment Variables Example
# Copy this file to .env.production and update with your production values

# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Public app URLs
FRONTEND_URL=https://sep.nhducminhqt.name.vn
BACKEND_URL=https://nhducminhqt.name.vn

# Redis
REDIS_PASSWORD=redis_password

# JWT
JWT_SIGNERKEY=your_jwt_signer_key_here
JWT_VALID_DURATION=3600
JWT_REFRESHABLE_DURATION=36000

# PayOS
PAYOS_CLIENT_ID=3af710f4-e502-4ddb-b99d-72ffa68f8423
PAYOS_API_KEY=b5087001-a7a7-4f60-af06-c941f374e5aa
PAYOS_CHECKSUM_KEY=7a6fd4e43ca930c32838b42f7976dd13c746ccc236a678b95585b68da743a5a4
PAYOS_RETURN_URL=https://nhducminhqt.name.vn/payment/success
PAYOS_CANCEL_URL=https://nhducminhqt.name.vn/payment/cancel

# Centrifugo
CENTRIFUGO_WS_URL=wss://nhducminhqt.name.vn/ws/connection/websocket

# MinIO public URL used to generate browser-accessible presigned URLs
MINIO_PUBLIC_ENDPOINT=https://nhducminhqt.name.vn
# Bucket storing OCR image assets referenced by lesson page content blocks
MINIO_OCR_CONTENT_BUCKET=slide-templates

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password
ADMIN_GMAIL=admin@mathmaster.com
ADMIN_FULLNAME=System Administrator

# Student
STUDENT_USERNAME=student
STUDENT_PASSWORD=your_secure_student_password
STUDENT_GMAIL=student@mathmaster.com
STUDENT_FULLNAME=Student User

# Teacher
TEACHER_USERNAME=teacher
TEACHER_PASSWORD=your_secure_teacher_password
TEACHER_GMAIL=teacher@mathmaster.com
TEACHER_FULLNAME=Teacher User
