# Local Environment Variables Example
# Copy this file to .env.local for local development with Docker Compose

# Spring profile
SPRING_PROFILES_ACTIVE=local

# Optional local URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080

# Local Redis
REDIS_PASSWORD=12345

# Local app initialization (set true if you want to seed default users)
APP_INIT_ENABLED=true

# Optional local credentials for seeded users
ADMIN_PASSWORD=Admin@123456
STUDENT_PASSWORD=Student@123456
TEACHER_PASSWORD=Teacher@123456

# Crawl data service
CRAWL_DATA_BASE_URL=http://localhost:8001
CRAWL_DATA_INTERNAL_API_KEY=change-me-in-production

# Firebase Configuration
FIREBASE_ENABLED=true
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_FILE=./.secrets/firebase-service-account.json

# Gemini API Configuration (Google AI)
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# MinIO bucket used for OCR image keys when crawler stores private object keys
MINIO_OCR_CONTENT_BUCKET=slide-templates
